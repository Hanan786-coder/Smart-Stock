<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:scrollbarStyle="outsideOverlay"
    android:scrollbars="vertical"
    android:fadeScrollbars="false"
    android:background="@drawable/login_background"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_marginTop="8dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/add_item"
            android:layout_width="match_parent"
            android:layout_height="100dp" android:layout_marginVertical="12dp" app:cardCornerRadius="28dp" app:cardElevation="12dp" app:strokeColor="#d32f2f"
            app:strokeWidth="2dp" android:backgroundTint="#f44336" android:foreground="?attr/selectableItemBackground">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:padding="24dp" android:gravity="center_vertical">

                <ImageView
                    android:layout_width="60dp" android:layout_height="60dp" android:src="@drawable/item_icon" app:tint="@android:color/white"
                    android:contentDescription="Add Item Icon" />

                <TextView
                    android:id="@+id/add_item_card_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/add_item"
                    android:textColor="@android:color/white"
                    android:textSize="23sp" android:textStyle="bold"
                    android:layout_marginStart="24dp" android:letterSpacing="0.05"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/add_employee"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_marginVertical="12dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="12dp"
            app:strokeColor="#d32f2f"
            app:strokeWidth="2dp"
            android:backgroundTint="#f44336"
            android:foreground="?attr/selectableItemBackground">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:padding="24dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:src="@drawable/employee_icon" app:tint="@android:color/white"
                    android:contentDescription="Add Employee Icon" />

                <TextView
                    android:id="@+id/add_employee_card_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/add_employee"
                    android:textColor="@android:color/white"
                    android:textSize="23sp"
                    android:textStyle="bold"
                    android:layout_marginStart="24dp"
                    android:letterSpacing="0.05"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/remove_item"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_marginVertical="12dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="12dp"
            app:strokeColor="#c62828"
            app:strokeWidth="2dp"
            android:backgroundTint="#e53935"
            android:foreground="?attr/selectableItemBackground">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:padding="24dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:src="@drawable/remove_item_icon" app:tint="@android:color/white"
                    android:contentDescription="Remove Item Icon" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/remove_item"
                    android:textColor="@android:color/white"
                    android:textSize="23sp"
                    android:textStyle="bold"
                    android:layout_marginStart="24dp"
                    android:letterSpacing="0.05"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/remove_employee"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_marginVertical="12dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="12dp"
            app:strokeColor="#c62828"
            app:strokeWidth="2dp"
            android:backgroundTint="#e53935"
            android:foreground="?attr/selectableItemBackground">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:padding="24dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:src="@drawable/remove_employee_icon" app:tint="@android:color/white"
                    android:contentDescription="Remove Employee Icon" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/remove_employee"
                    android:textColor="@android:color/white"
                    android:textSize="23sp"
                    android:textStyle="bold"
                    android:layout_marginStart="24dp"
                    android:letterSpacing="0.05"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>