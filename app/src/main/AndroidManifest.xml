<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:name=".SmartStockApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SmartStock"
        tools:targetApi="31">
        <activity
            android:name=".ViewWarehouse"
            android:exported="false" />
        <activity
            android:name=".AddWarehouse"
            android:exported="false" />
        <activity
            android:name=".EditEmployee"
            android:exported="false" />
        <activity
            android:name=".ChangeItemDetails"
            android:exported="false" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="com.example.smartstock.provider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <activity
            android:name=".RemoveEmployee"
            android:exported="false" />
        <activity
            android:name=".RemoveItem"
            android:exported="false" />
        <activity
            android:name=".MakeTransaction"
            android:exported="false"
            android:parentActivityName=".MainPage" />
        <activity
            android:name=".AddStock"
            android:exported="false" />
        <activity
            android:name=".View_Items_emp"
            android:exported="false" />
        <activity
            android:name=".AddEmployee"
            android:exported="false" />
        <activity
            android:name=".ViewEmployee"
            android:exported="false" />
        <activity
            android:name=".AddItems"
            android:exported="false"
            android:parentActivityName=".View_Items_admin" />
        <activity
            android:name=".View_Items_admin"
            android:exported="false"
            android:parentActivityName=".MainPage" />
        <activity
            android:name=".forgotPassword"
            android:exported="false"
            android:parentActivityName=".Login" />
        <activity
            android:name=".MainPage"
            android:exported="false" />
        <activity
            android:name=".registration_activity"
            android:exported="false"
            android:parentActivityName=".Login" />
        <activity
            android:name=".Login"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>